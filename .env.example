# ============================================
# AIAS Sign-In System — Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

SECRET_KEY=your-random-64-char-hex-string-here
FLASK_ENV=development
PORT=5000

# MongoDB Database
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/aias_db?retryWrites=true&w=majority

# Gmail SMTP
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# Redis / rate limiting
# Use redis://aias-redis:6379/0 when running with docker-compose.
# Use rediss://:YOUR_REDIS_KEY@YOUR_REDIS_NAME.redis.cache.windows.net:6380/0 for Azure Cache for Redis.
REDIS_URL=redis://localhost:6379/0
GLOBAL_RATE_LIMIT_LIMIT=100
GLOBAL_RATE_LIMIT_WINDOW=60

# Gunicorn production server tuning
WEB_CONCURRENCY=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120

# Google OAuth 2.0 (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# Zoom API (Server-to-Server OAuth)
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret
